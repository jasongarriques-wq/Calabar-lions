# Public (client + server). These are safe to expose — they're the
# publishable key, gated by Supabase RLS.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Server-only. Never expose. Used by trusted server routes only.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# Optional: external site URL used for OAuth redirects in production.
NEXT_PUBLIC_SITE_URL="https://www.calabarlion.com"
